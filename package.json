{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "postinstall": "tsx scripts/run-prisma.ts generate",
    "install:vps": "npm install --no-fund --no-audit --ignore-scripts && npm run db:generate",
    "db:generate": "tsx scripts/run-prisma.ts generate",
    "db:migrate": "tsx scripts/run-prisma.ts migrate dev",
    "db:migrate:deploy": "tsx scripts/run-prisma.ts migrate deploy",
    "db:push": "tsx scripts/run-prisma.ts db push",
    "db:studio": "tsx scripts/run-prisma.ts studio",
    "setup:vps": "bash scripts/install.sh",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:reload": "pm2 reload enxoval",
    "pm2:logs": "pm2 logs enxoval",
    "mobile:build": "vite build --mode mobile",
    "mobile:sync": "npm run mobile:build && npx cap sync",
    "mobile:android": "npm run mobile:sync && npx cap open android",
    "mobile:ios": "npm run mobile:sync && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.1",
    "@capacitor/cli": "^7.6.1",
    "@capacitor/core": "^7.6.1",
    "@capacitor/ios": "^7.6.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
