// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model EnxovalItem {
  id           String        @id @default(uuid())
  nome         String
  descricao    String?
  valor        Float
  prioridade   String        // Alta, Média, Baixa
  status       String        @default("Disponível") // Disponível, Reservado, Comprado
  reservadoPor String?
  reservas     Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model PurchasedItem {
  id         String   @id @default(uuid())
  nome       String
  categoria  String
  valor      Float
  dataCompra DateTime @default(now())
  createdAt  DateTime @default(now())
}

model Reservation {
  id          String      @id @default(uuid())
  enxovalId   String
  enxovalItem EnxovalItem @relation(fields: [enxovalId], references: [id])
  nome        String
  whatsapp    String
  mensagem    String?
  dataReserva DateTime    @default(now())
  createdAt   DateTime    @default(now())
}

model Settings {
  id                String  @id @default("global")
  pixKey            String  @default("")
  pixName           String  @default("")
  coupleNames       String  @default("Tais & Yran")
  weddingDate       String  @default("2027-02-02")
  whatsappNumber    String  @default("")
  whaticketApiUrl   String  @default("https://api.whaticketup.com.br/api/messages/send")
  whaticketToken    String  @default("")
  whaticketUserId   String  @default("")
  whaticketQueueId  String  @default("")
  whaticketTemplate String  @default("🎁 Nova reserva no site ({couple})\n\nPresente: {item}\nConvidado(a): {nome}\nWhatsApp: {whatsapp}\nRecado: {mensagem}\n\nOpções de presente: podem comprar o item por conta própria e entregar aos noivos, ou enviar o valor via PIX:\nChave PIX: {pixKey}\nTitular: {pixName}")
  whaticketSign     Boolean @default(true)
  whaticketClose    Boolean @default(false)
}
